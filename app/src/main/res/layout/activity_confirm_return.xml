<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".ConfirmReturnActivity">

    <ImageView
        android:id="@+id/ivConfirmReturnIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_handing_package"
        app:tint="#4CAF50" /> <!-- Green tint for 'Success' -->

    <TextView
        android:id="@+id/tvTransactionProductReturnTitle"
        style="@style/TextAppearance.Adatin.Cinzel.Heading5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Konfirmasi Pengembalian Barang"
        android:textAlignment="center"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivConfirmReturnIcon" />

    <TextView
        android:id="@+id/tvTransactionProductReturnDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Mohon pastikan barang dalam kondisi yang sesuai dengan saat diterima. Setelah Anda mengonfirmasi pengembalian, status pesanan akan diperbarui menjadi selesai."
        android:textAlignment="center"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTransactionProductReturnTitle" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvConfirmReturnPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTransactionProductReturnDescription">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivConfirmReturnProductImage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/avatars" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Anda menyewa:"/>
                <TextView
                    android:id="@+id/tvConfirmReturnProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="{{ProductName}}"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvConfirmReturnProductSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ukuran: {{ProductSize}}" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnTransactionProductReturnAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ya, Kembalikan Barang"
            android:backgroundTint="#4CAF50" /> <!-- Success Green -->

        <Button
            android:id="@+id/btnTransactionProductReturnBack"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Kembali" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>