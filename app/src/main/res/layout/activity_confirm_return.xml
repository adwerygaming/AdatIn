<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ConfirmReturnActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:tint="#FDFDFD"
            app:srcCompat="@drawable/ic_handing_package" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tvConfirmReturnTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kembalikan {{ProductName}}?"
                android:textAlignment="center"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="yakin nich mo balikin?"
                android:textAlignment="center" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmReturn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ya, balikin" />

        <Button
            android:id="@+id/btnCancelReturn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ntar deh" />
    </LinearLayout>
</LinearLayout>