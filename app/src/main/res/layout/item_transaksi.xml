<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/TransactionProductMainGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvTransactionProductInvoiceID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="{{ProductInvoiceID}}"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="#757575"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTransactionProductStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="{{ProductStatus}}"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#E53935" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/TransactionProductDividerGroup"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@id/tvTransactionProductInvoiceID" />

        <ImageView
            android:id="@+id/ivTransactionProductImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/TransactionProductDividerGroup" />

        <TextView
            android:id="@+id/tvTransactionProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="{{ProductName}}"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivTransactionProductImage"
            app:layout_constraintTop_toTopOf="@id/ivTransactionProductImage" />

        <TextView
            android:id="@+id/tvTransactionProductSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Ukuran: {{ProductSize}}"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTransactionProductName"
            app:layout_constraintTop_toBottomOf="@id/tvTransactionProductName" />

        <TextView
            android:id="@+id/tvTransactionProductRentalDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:text="{{ProductCity}} • {{ProductDetails}}"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/tvTransactionProductSubtotal"
            app:layout_constraintStart_toStartOf="@id/tvTransactionProductName"
            app:layout_constraintTop_toBottomOf="@id/tvTransactionProductSize" />

        <TextView
            android:id="@+id/tvTransactionProductSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="{{ProductSubtotal}}"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivTransactionProductImage"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/TransactionProductActionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="end"
            app:layout_constraintTop_toBottomOf="@id/ivTransactionProductImage">

            <Button
                android:id="@+id/btnTransactionProductCancel"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Batalkan"
                android:visibility="gone"
                tools:visibility="visible" />

            <Button
                android:id="@+id/btnTransactionProductPickup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Konfirmasi Ambil"
                android:visibility="gone"
                tools:visibility="visible" />

            <Button
                android:id="@+id/btnTransactionProductReturn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kembalikan"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>